@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix lapras: <http://lapras.org/rule/> .

# --- Front Nap Mode — Threshold-Aware Rules ---
# Agent: "front" | Light config: bri=100, hue=100 (warm, dim) | Aircon: device 322207, temp_down
# Light branch:  near + dark  → light on;  far OR near + bright → light off
# Aircon branch: near + hot   → aircon on; far OR near + cool   → aircon off
# (Mode profile is set by agent preset; rule logic is identical to front-read)

# ── Shared conditions ──────────────────────────────────────────────────────────

lapras:TFN_NearCond
    lapras:hasSensor "proximity_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "near" .

lapras:TFN_FarCond
    lapras:hasSensor "proximity_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "far" .

lapras:TFN_DarkCond
    lapras:hasSensor "light_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "dark" .

lapras:TFN_BrightCond
    lapras:hasSensor "light_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "bright" .

lapras:TFN_HotCond
    lapras:hasSensor "temperature_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "hot" .

lapras:TFN_CoolCond
    lapras:hasSensor "temperature_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "cool" .

lapras:TFN_LightOffCond
    lapras:hasSensor "light_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "off" .

lapras:TFN_LightOnCond
    lapras:hasSensor "light_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "on" .

lapras:TFN_AirconOffCond
    lapras:hasSensor "aircon_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "off" .

lapras:TFN_AirconOnCond
    lapras:hasSensor "aircon_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "on" .

# ── Actions ────────────────────────────────────────────────────────────────────

lapras:TFN_LightOnAction  lapras:hasStateUpdate '{"light_power": "on"}' .
lapras:TFN_LightOffAction lapras:hasStateUpdate '{"light_power": "off"}' .
lapras:TFN_AirconOnAction  lapras:hasStateUpdate '{"aircon_power": "on"}' .
lapras:TFN_AirconOffAction lapras:hasStateUpdate '{"aircon_power": "off"}' .

# ── Light branch ────────────────────────────────────────────────────────────────

# Light ON: person near AND ambient light is dark
lapras:TFN_LightOnRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_NearCond ;
    lapras:hasCondition lapras:TFN_LightOffCond ;
    lapras:hasCondition lapras:TFN_DarkCond ;
    lapras:hasAction lapras:TFN_LightOnAction .

# Light OFF: no one present
lapras:TFN_LightOffFarRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_LightOnCond ;
    lapras:hasCondition lapras:TFN_FarCond ;
    lapras:hasAction lapras:TFN_LightOffAction .

# Light OFF: person near but ambient already bright
lapras:TFN_LightOffBrightRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_LightOnCond ;
    lapras:hasCondition lapras:TFN_NearCond ;
    lapras:hasCondition lapras:TFN_BrightCond ;
    lapras:hasAction lapras:TFN_LightOffAction .

# ── Aircon branch ───────────────────────────────────────────────────────────────

# Aircon ON: person near AND temperature is hot
lapras:TFN_AirconOnRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_NearCond ;
    lapras:hasCondition lapras:TFN_AirconOffCond ;
    lapras:hasCondition lapras:TFN_HotCond ;
    lapras:hasAction lapras:TFN_AirconOnAction .

# Aircon OFF: no one present
lapras:TFN_AirconOffFarRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_AirconOnCond ;
    lapras:hasCondition lapras:TFN_FarCond ;
    lapras:hasAction lapras:TFN_AirconOffAction .

# Aircon OFF: person near but temperature is cool
lapras:TFN_AirconOffCoolRule a lapras:Rule ;
    lapras:hasAgent "front" ;
    lapras:hasCondition lapras:TFN_AirconOnCond ;
    lapras:hasCondition lapras:TFN_NearCond ;
    lapras:hasCondition lapras:TFN_CoolCond ;
    lapras:hasAction lapras:TFN_AirconOffAction .
