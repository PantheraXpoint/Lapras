@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix lapras: <http://lapras.org/rule/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- All Area Repair-Clean Mode Rules (demo baseline) ---
# For agent_id "all" - 6-light demo subset; lights 6 and 7 are reserved as failover backups.
# Active light_ids baseline: ["1","2","3","5","8","10"]
# Aircon config: both devices 164793 & 322207, both OFF always (clean mode behavior)

# Turn ON lights only when person is near (clean mode - aircons stay OFF).
# Note: no IsOffCondition precondition here — we want the rule to fire on
# every proximity=near update so that switching to this rule from another
# rule with a different light_ids set produces an immediate, visible change.
# The agent's __turn_on_lights_by_ids is idempotent and also turns off any
# lights NOT in light_ids, so re-fires don't cause flicker.
lapras:AllCleanOnWhenNearRule a lapras:Rule ;
    lapras:hasAgent "all" ;
    lapras:hasCondition lapras:AllCleanIsNearCondition ;
    lapras:hasAction lapras:SetAllCleanPowerOn .

lapras:AllCleanIsNearCondition
    lapras:hasSensor "proximity_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "near" .

lapras:AllCleanIsOffCondition
    lapras:hasSensor "light_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "off" .

lapras:SetAllCleanPowerOn lapras:hasStateUpdate '{"power": "on", "light_ids": ["1","2","3","5","8","10"]}' .

# Turn OFF lights when person is far
lapras:AllCleanOffWhenFarRule a lapras:Rule ;
    lapras:hasAgent "all" ;
    lapras:hasCondition lapras:AllCleanIsOnCondition ;
    lapras:hasCondition lapras:AllCleanIsFarCondition ;
    lapras:hasAction lapras:SetAllCleanPowerOff .

lapras:AllCleanIsOnCondition
    lapras:hasSensor "light_power" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "on" .

lapras:AllCleanIsFarCondition
    lapras:hasSensor "proximity_status" ;
    lapras:hasOperator lapras:equals ;
    lapras:hasValue "far" .

lapras:SetAllCleanPowerOff lapras:hasStateUpdate '{"power": "off", "light_ids": ["1","2","3","5","8","10"]}' .
